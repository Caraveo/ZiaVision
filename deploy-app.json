{
  "schemaVersion": "2.2",
  "description": "Deploy Zia Vision application",
  "parameters": {},
  "mainSteps": [
    {
      "action": "aws:runShellScript",
      "name": "deployApplication",
      "inputs": {
        "runCommand": [
          "cd /var/www/html",
          "aws s3 cp s3://ziavision-deploy/deployment.zip .",
          "unzip -o deployment.zip",
          "rm deployment.zip",
          "systemctl restart nginx"
        ]
      }
    }
  ]
} 